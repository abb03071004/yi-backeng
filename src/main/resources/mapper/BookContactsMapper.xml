<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.yibackend.mapper.BookContactsMapper">
    <insert id="insertBatch">
        insert into book_contacts (book_id,number,create_time) VALUES
        <foreach collection="bookContactsList" item="contact" separator=",">
            (#{contact.bookId},#{contact.number},#{contact.createTime})
        </foreach>
    </insert>
</mapper>